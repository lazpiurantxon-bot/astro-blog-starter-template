---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <!-- ===== HONEY DRIP (decorative) ===== -->
    <svg
      class="ezti-honey-drip"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1440 105"
      preserveAspectRatio="xMidYMin meet"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <linearGradient id="honey-drip-gradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#D4A030" />
          <stop offset="45%"  stop-color="#C8922A" />
          <stop offset="100%" stop-color="#9A6A15" />
        </linearGradient>
      </defs>
      <path
        fill="url(#honey-drip-gradient)"
        d="
          M 0 0
          L 1440 0
          L 1440 20
          Q 1418 20 1391 20
          C 1391 20 1389 21 1387 25
          C 1384 34 1381 55 1378 67
          C 1376 74 1374 79 1372 81
          C 1370 83 1368 83 1366 81
          C 1364 79 1362 74 1360 67
          C 1357 55 1354 33 1351 24
          C 1349 21 1347 20 1345 20
          Q 1310 19 1270 20
          Q 1248 20 1225 20
          C 1225 20 1222 21 1220 26
          C 1217 37 1214 63 1211 77
          C 1209 85 1207 91 1205 93
          C 1203 95 1201 95 1199 93
          C 1197 91 1195 85 1193 77
          C 1190 63 1187 37 1184 26
          C 1182 21 1180 20 1178 20
          Q 1145 19 1115 20
          Q 1094 20 1070 20
          C 1070 20 1068 21 1066 25
          C 1063 33 1061 52 1059 63
          C 1057 70 1055 74 1053 76
          C 1051 77 1049 77 1047 75
          C 1045 73 1043 69 1041 62
          C 1039 51 1037 33 1035 24
          C 1033 21 1031 20 1029 20
          Q 996 19 963 20
          Q 940 20 910 20
          C 910 20 907 21 905 27
          C 902 38 899 66 896 79
          C 894 87 892 92 890 94
          C 888 96 886 96 884 94
          C 882 92 880 87 878 79
          C 875 66 872 38 869 27
          C 867 21 865 20 863 20
          Q 828 19 795 20
          Q 773 20 748 20
          C 748 20 746 21 744 25
          C 741 34 739 54 737 65
          C 735 72 733 77 731 78
          C 729 79 727 79 725 77
          C 723 75 721 70 719 63
          C 717 52 715 33 713 24
          C 711 21 709 20 707 20
          Q 672 19 638 20
          Q 616 20 593 20
          C 593 20 590 21 588 27
          C 585 38 582 67 579 81
          C 577 89 575 94 573 96
          C 571 98 569 98 567 96
          C 565 94 563 89 561 81
          C 558 67 555 38 552 27
          C 550 21 548 20 546 20
          Q 512 19 478 20
          Q 456 20 430 20
          C 430 20 428 21 426 26
          C 423 36 421 58 419 70
          C 417 77 415 82 413 83
          C 411 85 409 84 407 82
          C 405 80 403 75 401 68
          C 399 56 397 35 395 26
          C 393 21 391 20 389 20
          Q 354 19 320 20
          Q 298 20 262 20
          C 262 20 259 21 257 27
          C 254 38 251 65 248 78
          C 246 86 244 91 242 93
          C 240 95 238 95 236 93
          C 234 91 232 86 230 78
          C 227 65 224 38 221 27
          C 219 21 217 20 215 20
          Q 181 19 148 20
          Q 126 20 100 20
          C 100 20 98 21 96 25
          C 93 33 91 52 89 62
          C 87 69 85 73 83 74
          C 81 75 79 75 77 73
          C 75 71 73 67 71 60
          C 69 49 67 31 65 23
          C 63 20 61 19 59 20
          Q 30 20 0 20
          Z
        "
      />
    </svg>

    <!-- ===== HERO ===== -->
    <section class="hero" id="hero">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <h1 class="hero-wordmark">EZTI</h1>
        <p class="hero-headline">MIEL, SAL Y LIMÓN PARA SEGUIR.</p>
        <p class="hero-headline-eu">Ezti. Limoia. Gatza. Jarraitzeko.</p>
        <p class="hero-sub">Energía real. Ingredientes que reconoces.</p>
        <div class="hero-ctas">
          <a href="#formulario" class="btn btn-primary">Quiero probarlo</a>
          <a href="#producto" class="btn btn-outline">Saber más</a>
        </div>
      </div>

      <a href="#manifiesto" class="scroll-hint" aria-label="Seguir leyendo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 9L12 15L18 9" stroke="#C8922A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </section>

    <!-- ===== MANIFIESTO ===== -->
    <section class="manifiesto" id="manifiesto">
      <div class="container">
        <div class="manifesto-tag">Nada que ocultar. Nada que sobra.</div>
        <div class="manifesto-body">
          <p>No necesitas una fórmula imposible de pronunciar.</p>
          <p>Necesitas energía que entiendas.</p>
          <p class="manifesto-ingredients">Miel. Sal. Limón.</p>
          <p>Nada más de lo necesario.</p>
          <p class="manifesto-close">EZTI nace de días largos y cuerpos al límite. De esfuerzo que no tiene hora de fin.<br/>
          <strong>Energía real. Para seguir.</strong></p>
        </div>
      </div>
    </section>

    <!-- ===== EDITORIAL STRIP ===== -->
    <section class="editorial-strip">
      <div class="editorial-photo-wrap">
        <img
          src="/esfuerzo-cima.jpg"
          alt=""
          aria-hidden="true"
          class="editorial-photo"
        />
        <div class="editorial-overlay">
          <blockquote class="editorial-quote">
            Hecho para quien<br/>elige lo difícil.<br/>
            <span>Y no lo hace por nadie más.</span>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- ===== EL PRODUCTO ===== -->
    <section class="producto" id="producto">
      <div class="producto-split">
        <div class="producto-photo-panel">
          <img
            src="/producto-ezti.jpg"
            alt="Sachet de EZTI — gel energético natural — en terreno de montaña"
            class="producto-photo"
          />
        </div>
        <div class="producto-features">
          <div class="section-label">El producto</div>
          <h2 class="section-title">GEL ENERGÉTICO<br/>NATURAL</h2>
          <p class="section-intro">
            Formato sachet para quienes afrontan esfuerzos prolongados. Formulación mínima, ingredientes reconocibles, diseñado para consumir sin perder el ritmo.
          </p>
          <div class="product-list">
            <div class="product-card">
              <span class="product-num">01</span>
              <div>
                <h3>Formato sachet</h3>
                <p>Ligero, portable, apertura rápida. Para usarse en movimiento sin perder el ritmo.</p>
              </div>
            </div>
            <div class="product-card">
              <span class="product-num">02</span>
              <div>
                <h3>Etiqueta limpia</h3>
                <p>Tres ingredientes. Todos los que necesitas. Ninguno que no sepas qué es.</p>
              </div>
            </div>
            <div class="product-card">
              <span class="product-num">03</span>
              <div>
                <h3>Probado en terreno</h3>
                <p>Desarrollado con personas que afrontan esfuerzos reales. Feedback de uso real.</p>
              </div>
            </div>
            <div class="product-card">
              <span class="product-num">04</span>
              <div>
                <h3>Hecho desde Euskadi</h3>
                <p>Miel, sal y limón de origen trazable. Un producto con raíz en el territorio.<br/><em>Euskal Herrian egina.</em></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== INGREDIENTES ===== -->
    <section class="ingredientes" id="ingredientes">
      <div class="container">
        <div class="section-label" style="color: #C8922A;">Formulación</div>
        <h2 class="section-title ing-title">TRES INGREDIENTES.<br/>MUCHO CRITERIO.</h2>

        <div class="ing-photo">
          <img src="/miel-anana.jpg" alt="Miel natural vertiéndose junto a sal de manantial de Añana" />
        </div>

        <div class="ing-grid">
          <div class="ing-item">
            <div class="ing-number">01</div>
            <!-- FOTO opcional: macro miel — reemplazar con /ing-honey.jpg -->
            <h3>Miel</h3>
            <p>Aporta glucosa y fructosa de forma intrínseca — los mismos dos azúcares que la mayoría de geles combinan en su formulación. Misma energía, ingrediente real. Energía desde un ingrediente real.</p>
          </div>
          <div class="ing-item">
            <div class="ing-number">02</div>
            <!-- FOTO opcional: limón — reemplazar con /ing-lemon.jpg -->
            <h3>Limón</h3>
            <p>Perfil sensorial ácido que equilibra el dulzor de la miel y facilita el consumo durante el esfuerzo. Contribuye al sabor en un momento de alta demanda sensorial.</p>
          </div>
          <div class="ing-item">
            <div class="ing-number">03</div>
            <!-- FOTO opcional: sal — reemplazar con /ing-salt.jpg -->
            <h3>Sal de Añana</h3>
            <p>Sodio en el contexto del esfuerzo prolongado. La sal de manantial de Añana — identidad y trazabilidad propia del territorio vasco.</p>
          </div>
        </div>

        <div class="ing-note">
          <span>Sin cafeína</span>
          <span class="ing-sep" aria-hidden="true">/</span>
          <span>Sin colorantes</span>
          <span class="ing-sep" aria-hidden="true">/</span>
          <span>Sin conservantes</span>
          <span class="ing-sep" aria-hidden="true">/</span>
          <span>Sin aditivos innecesarios</span>
        </div>
      </div>
    </section>

    <!-- ===== PRUEBA REAL ===== -->
    <section class="prueba" id="prueba">
      <div class="container">
        <div class="section-label" style="color: #C8922A;">VALIDADO EN TERRENO REAL</div>
        <h2 class="section-title prueba-title">No lo decimos nosotros.<br/>Lo dicen quienes lo usaron.</h2>

        <div class="prueba-stats">
          <div class="prueba-stat">
            <span class="prueba-stat-number">~85</span>
            <span class="prueba-stat-label">unidades probadas en esfuerzo real</span>
          </div>
          <div class="prueba-stat">
            <span class="prueba-stat-number">0/8</span>
            <span class="prueba-stat-label">molestias digestivas en panel controlado</span>
          </div>
          <div class="prueba-stat">
            <span class="prueba-stat-number">2</span>
            <span class="prueba-stat-label">atletas lo usaron en competición real sustituyendo su gel habitual</span>
          </div>
          <div class="prueba-stat">
            <span class="prueba-stat-number">15-20</span>
            <span class="prueba-stat-label">personas preguntaron dónde comprarlo en Zegama-Aizkorri sin que hubiera nada en venta</span>
          </div>
        </div>

        <div class="prueba-quotes">
          <blockquote class="prueba-quote">
            <p>«Esto es comida. No sabe artificial.»</p>
            <cite>— Tester, trail runner, panel controlado</cite>
          </blockquote>
          <blockquote class="prueba-quote">
            <p>«Se nota que la miel es muy buena.»</p>
            <cite>— Tester, ciclismo + running, 4 horas</cite>
          </blockquote>
          <blockquote class="prueba-quote">
            <p>«Menos empalagoso de lo que esperaba.»</p>
            <cite>— Tester, Zegama-Aizkorri</cite>
          </blockquote>
        </div>

        <div class="prueba-science">
          <div class="prueba-science-label">BASE CIENTÍFICA</div>
          <p>Un estudio de 2025 en el International Journal of Sport Nutrition and Exercise Metabolism comparó la ingesta de miel frente a un producto comercial de carbohidratos durante 3 horas de ciclismo y no encontró diferencias relevantes en oxidación de carbohidratos ni en tiempo hasta la fatiga.</p>
          <cite>Fortis et al. (2025). Int. J. Sport Nutr. Exerc. Metab., 35(5):424–432.</cite>
        </div>

        <div class="prueba-cta">
          <a href="#formulario" class="btn btn-primary">Quiero ser tester</a>
        </div>
      </div>
    </section>

    <!-- ===== EL ESFUERZO ===== -->
    <section class="paraquien" id="paraquien">
      <div class="paraquien-grid">
        <div class="paraquien-moments">
          <div class="paraquien-moments-inner">
            <div class="section-label">El esfuerzo</div>
            <h2 class="section-title">NO ES PARA<br/>UN DEPORTE.<br/>ES PARA<br/>UN ESFUERZO.</h2>

            <div class="moments-list">
              <div class="moment-row">
                <span class="moment-num">01</span>
                <p>Cuando llevas horas en movimiento y aún queda recorrido.</p>
              </div>
              <div class="moment-row">
                <span class="moment-num">02</span>
                <p>La sesión que dura más de lo que esperabas.</p>
              </div>
              <div class="moment-row">
                <span class="moment-num">03</span>
                <p>El momento en que el cuerpo pide parar y decides seguir.</p>
              </div>
              <div class="moment-row">
                <span class="moment-num">04</span>
                <p>Trabajo físico que empieza temprano y no para.</p>
              </div>
              <div class="moment-row">
                <span class="moment-num">05</span>
                <p>Cualquier objetivo que exige sostener el esfuerzo durante horas.</p>
              </div>
            </div>

            <p class="moments-close">Si tu esfuerzo merece respeto,<br/>tu energía también.</p>
          </div>
        </div>

        <div class="paraquien-photo-panel" aria-hidden="true">
          <img
            src="/terreno-esfuerzo.jpg"
            alt=""
            class="paraquien-photo"
          />
        </div>
      </div>
    </section>

    <!-- ===== FORMULARIO ===== -->
    <section class="formulario" id="formulario">
      <div class="container">
        <div class="form-wrapper">
          <div class="form-intro">
            <div class="section-label" style="color: #C8922A;">Acceso anticipado</div>
            <h2 class="section-title">QUIERO<br/>PROBAR EZTI.</h2>
            <p>
              Estamos en fase de validación. Si afrontas esfuerzos prolongados con regularidad y quieres ser de los primeros en probar EZTI, déjanos tus datos.
            </p>
            <ul class="form-perks">
              <li>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20"><path d="M4 10L8 14L16 6" stroke="#C8922A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Acceso prioritario al primer lote
              </li>
              <li>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20"><path d="M4 10L8 14L16 6" stroke="#C8922A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Muestra gratuita para testing real
              </li>
              <li>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20"><path d="M4 10L8 14L16 6" stroke="#C8922A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Tu feedback mejora el producto
              </li>
            </ul>
          </div>

          <div class="form-card">
            <p class="form-pretag">Testing real. Primer lote limitado.</p>
            <form id="contact-form" novalidate>
              <div class="form-group">
                <label for="nombre">Nombre</label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  placeholder="Tu nombre"
                  required
                  autocomplete="name"
                />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="tu@email.com"
                  required
                  autocomplete="email"
                />
              </div>
              <div class="form-group">
                <label for="deporte">Contexto de esfuerzo</label>
                <select id="deporte" name="deporte" required>
                  <option value="" disabled selected>¿Cuál es tu entorno?</option>
                  <option value="resistencia">Resistencia (ciclismo, triatlón, natación)</option>
                  <option value="running">Running (trail o asfalto)</option>
                  <option value="montana">Montaña y outdoor</option>
                  <option value="funcional">CrossFit, Hyrox o funcional</option>
                  <option value="combate">Deportes de combate</option>
                  <option value="trabajo">Trabajo físico exigente</option>
                  <option value="otro">Otro esfuerzo sostenido</option>
                </select>
              </div>
              <div class="form-group">
                <label for="mensaje">¿Por qué quieres probar EZTI? <span class="label-optional">(opcional)</span></label>
                <textarea
                  id="mensaje"
                  name="mensaje"
                  rows="3"
                  placeholder="Cuéntanos sobre tu entrenamiento o lo que buscas..."
                ></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-full" id="submit-btn">
                <span class="btn-text">Quiero probar EZTI</span>
                <span class="btn-loading" style="display:none">Enviando...</span>
              </button>
              <p class="form-privacy">
                Tus datos solo se usarán para contactarte sobre el proceso de testing de EZTI. Sin spam.
              </p>
            </form>

            <div class="form-success" id="form-success" style="display:none">
              <div class="success-icon" aria-hidden="true">
                <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg" width="60" height="60">
                  <circle cx="30" cy="30" r="28" stroke="#C8922A" stroke-width="2"/>
                  <path d="M18 30L26 38L42 22" stroke="#C8922A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>¡Apuntado!</h3>
              <p>Te avisaremos en cuanto tengamos unidades disponibles para testing. Energía real. Para seguir.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #080807;
    padding: 80px 0 60px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 110%, rgba(200, 146, 42, 0.06) 0%, transparent 55%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    max-width: 860px;
  }

  /* ===== HONEY DRIP SVG ===== */
  .ezti-honey-drip {
    display: block;
    width: 100%;
    height: auto;
    max-height: 80px;
    margin-bottom: -1px;
    pointer-events: none;
    user-select: none;
    position: relative;
    z-index: 99;
  }

  .hero-wordmark {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(5rem, 18vw, 13rem);
    color: #EDE7D8;
    letter-spacing: 0.06em;
    line-height: 0.9;
    margin-bottom: 1.5rem;
  }

  .hero-headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(1.1rem, 3.5vw, 1.85rem);
    color: #EDE7D8;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.25rem;
  }

  .hero-headline-eu {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(0.75rem, 2.3vw, 1.25rem);
    color: #EDE7D8;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
    opacity: 0.55;
  }

  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: rgba(237, 231, 216, 0.65);
    letter-spacing: 0.04em;
    margin: 0 0 2.75rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    animation: bounce 2.5s ease-in-out infinite;
    opacity: 0.5;
    transition: opacity 0.2s;
    display: flex;
  }

  .scroll-hint:hover { opacity: 1; }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0.85rem 2rem;
    border-radius: 2px;
    border: 2px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
    line-height: 1;
  }

  .btn-primary {
    background: #C8922A;
    color: #080807;
    border-color: #C8922A;
  }

  .btn-primary:hover {
    background: #EDE7D8;
    border-color: #EDE7D8;
    color: #080807;
  }

  .btn-outline {
    background: transparent;
    color: #EDE7D8;
    border-color: rgba(237, 231, 216, 0.3);
  }

  .btn-outline:hover {
    border-color: #EDE7D8;
    color: #EDE7D8;
  }

  .btn-full { width: 100%; }
  .btn:disabled { opacity: 0.6; cursor: not-allowed; }

  /* ===== MANIFIESTO ===== */
  .manifiesto {
    background: #EDE7D8;
    padding: 7rem 0;
  }

  .manifesto-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(8, 8, 7, 0.4);
    margin-bottom: 3rem;
  }

  .manifesto-body { max-width: 680px; }

  .manifesto-body p {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: #5C5748;
    line-height: 1.8;
    margin-bottom: 0.6rem;
  }

  .manifesto-ingredients {
    font-family: 'Barlow Condensed', sans-serif !important;
    font-weight: 900 !important;
    font-size: clamp(2.5rem, 6vw, 4.5rem) !important;
    color: #080807 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    margin: 1.75rem 0 !important;
    line-height: 1 !important;
  }

  .manifesto-close {
    margin-top: 1.75rem !important;
    color: #5C5748 !important;
    font-size: clamp(0.95rem, 2vw, 1.15rem) !important;
  }

