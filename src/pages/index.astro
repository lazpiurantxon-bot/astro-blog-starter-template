---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <!-- ===== HERO ===== -->
    <section class="hero" id="hero">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <div class="honey-drip" aria-hidden="true">
          <svg viewBox="0 0 240 190" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMax meet">
            <path d="M0,0 L240,0 L240,12 Q200,17 160,11 Q120,5 80,14 Q40,19 0,12 Z" fill="#C8922A"/>
            <path d="M20,12 C20,12 27,15 26,54 C25,74 29,89 27,104 C25,114 18,114 17,104 C14,91 18,71 17,51 C16,30 19,12 20,12 Z" fill="#C8922A"/>
            <path d="M72,12 C72,12 80,16 79,74 C78,104 83,127 80,145 C78,157 71,157 69,145 C66,129 70,105 69,75 C68,45 71,12 72,12 Z" fill="#C8922A"/>
            <path d="M120,12 C120,12 128,15 127,47 C126,61 130,75 128,87 C126,96 120,96 118,87 C116,75 119,59 118,45 C117,27 120,12 120,12 Z" fill="#C8922A"/>
            <path d="M166,12 C166,12 174,16 173,67 C172,89 177,107 175,121 C173,131 167,131 165,121 C163,107 166,87 165,64 C164,39 165,12 166,12 Z" fill="#C8922A"/>
            <path d="M210,12 C210,12 218,15 217,41 C216,54 220,65 218,74 C216,81 210,81 209,74 C207,64 210,51 209,39 C208,25 209,12 210,12 Z" fill="#C8922A"/>
          </svg>
        </div>

        <h1 class="hero-wordmark">EZTI</h1>
        <p class="hero-headline">MIEL, SAL Y LIMÓN PARA SEGUIR.</p>
        <p class="hero-sub">Energía real. Ingredientes que reconoces.</p>
        <div class="hero-ctas">
          <a href="#formulario" class="btn btn-primary">Quiero probarlo</a>
          <a href="#producto" class="btn btn-outline">Saber más</a>
        </div>
      </div>

      <a href="#manifiesto" class="scroll-hint" aria-label="Seguir leyendo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 9L12 15L18 9" stroke="#C8922A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </section>

    <!-- ===== MANIFIESTO ===== -->
    <section class="manifiesto" id="manifiesto">
      <div class="container">
        <div class="manifesto-tag">Nada que ocultar. Nada que sobra.</div>
        <div class="manifesto-body">
          <p>No necesitas una fórmula imposible de pronunciar.</p>
          <p>Necesitas energía que entiendas.</p>
          <p class="manifesto-ingredients">Miel. Sal. Limón.</p>
          <p>Nada más de lo necesario.</p>
          <p class="manifesto-close">EZTI nace de días largos y cuerpos al límite. De esfuerzo que no tiene hora de fin.<br/>
          <strong>Energía real. Para seguir.</strong></p>
        </div>
      </div>
    </section>

    <!-- ===== EDITORIAL STRIP ===== -->
    <section class="editorial-strip">
      <div class="editorial-photo-wrap">
        <img
          src="/esfuerzo-cima.jpg"
          alt=""
          aria-hidden="true"
          class="editorial-photo"
        />
        <div class="editorial-overlay">
          <blockquote class="editorial-quote">
            Hecho para quien<br/>elige lo difícil.<br/>
            <span>Y no lo hace por nadie más.</span>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- ===== EL PRODUCTO ===== -->
    <section class="producto" id="producto">
      <div class="producto-split">
        <div class="producto-photo-panel">
          <img
            src="/producto-ezti.jpg"
            alt="Sachet de EZTI — gel energético natural — en terreno de montaña"
            class="producto-photo"
          />
        </div>
        <div class="producto-features">
          <div class="section-label">El producto</div>
          <h2 class="section-title">GEL ENERGÉTICO<br/>NATURAL</h2>
          <p class="section-intro">
            Formato sachet para quienes afrontan esfuerzos prolongados. Formulación mínima, ingredientes reconocibles, diseñado para consumir sin perder el ritmo.
          </p>
          <div class="product-list">
            <div class="product-card">
              <span class="product-num">01</span>
              <div>
                <h3>Formato sachet</h3>
                <p>Ligero, portable, apertura rápida. Para usarse en movimiento sin perder el ritmo.</p>
              </div>
            </div>
            <div class="product-card">
              <span class="product-num">02</span>
              <div>
                <h3>Etiqueta limpia</h3>
                <p>Tres ingredientes. Todos los que necesitas. Ninguno que no sepas qué es.</p>
              </div>
            </div>
            <div class="product-card">
              <span class="product-num">03</span>
              <div>
                <h3>Probado en terreno</h3>
                <p>Desarrollado con personas que afrontan esfuerzos reales. Feedback de uso real.</p>
              </div>
            </div>
            <div class="product-card">
              <span class="product-num">04</span>
              <div>
                <h3>Hecho desde Euskadi</h3>
                <p>Miel, sal y limón de origen trazable. Un producto con raíz en el territorio.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== INGREDIENTES ===== -->
    <section class="ingredientes" id="ingredientes">
      <div class="container">
        <div class="section-label" style="color: #C8922A;">Formulación</div>
        <h2 class="section-title ing-title">TRES INGREDIENTES.<br/>MUCHO CRITERIO.</h2>

        <div class="ing-photo">
          <img src="/miel-anana.jpg" alt="Miel natural vertiéndose junto a sal de manantial de Añana" />
        </div>

        <div class="ing-grid">
          <div class="ing-item">
            <div class="ing-number">01</div>
            <!-- FOTO opcional: macro miel — reemplazar con /ing-honey.jpg -->
            <h3>Miel</h3>
            <p>Aporta glucosa y fructosa de forma natural — los mismos dos carbohidratos que los geles premium combinan artificialmente. Energía rápida y sostenida desde un ingrediente real.</p>
          </div>
          <div class="ing-item">
            <div class="ing-number">02</div>
            <!-- FOTO opcional: limón — reemplazar con /ing-lemon.jpg -->
            <h3>Limón</h3>
            <p>Perfil sensorial ácido que equilibra el dulzor de la miel y facilita el consumo durante el esfuerzo. Contribuye al sabor en un momento de alta demanda sensorial.</p>
          </div>
          <div class="ing-item">
            <div class="ing-number">03</div>
            <!-- FOTO opcional: sal — reemplazar con /ing-salt.jpg -->
            <h3>Sal de Añana</h3>
            <p>Sodio en el contexto del esfuerzo prolongado. La sal de manantial de Añana — identidad y trazabilidad propia del territorio vasco.</p>
          </div>
        </div>

        <div class="ing-note">
          <span>Sin cafeína</span>
          <span class="ing-sep" aria-hidden="true">/</span>
          <span>Sin colorantes</span>
          <span class="ing-sep" aria-hidden="true">/</span>
          <span>Sin conservantes</span>
          <span class="ing-sep" aria-hidden="true">/</span>
          <span>Sin aditivos innecesarios</span>
        </div>
      </div>
    </section>

    <!-- ===== EL ESFUERZO ===== -->
    <section class="paraquien" id="paraquien">
      <div class="paraquien-grid">
        <div class="paraquien-moments">
          <div class="paraquien-moments-inner">
            <div class="section-label">El esfuerzo</div>
            <h2 class="section-title">NO ES PARA<br/>UN DEPORTE.<br/>ES PARA<br/>UN ESFUERZO.</h2>

            <div class="moments-list">
              <div class="moment-row">
                <span class="moment-num">01</span>
                <p>Cuando llevas horas en movimiento y aún queda recorrido.</p>
              </div>
              <div class="moment-row">
                <span class="moment-num">02</span>
                <p>La sesión que dura más de lo que esperabas.</p>
              </div>
              <div class="moment-row">
                <span class="moment-num">03</span>
                <p>El momento en que el cuerpo pide parar y decides seguir.</p>
              </div>
              <div class="moment-row">
                <span class="moment-num">04</span>
                <p>Trabajo físico que empieza temprano y no para.</p>
              </div>
              <div class="moment-row">
                <span class="moment-num">05</span>
                <p>Cualquier objetivo que exige sostener el esfuerzo durante horas.</p>
              </div>
            </div>

            <p class="moments-close">Si tu esfuerzo merece respeto,<br/>tu energía también.</p>
          </div>
        </div>

        <div class="paraquien-photo-panel" aria-hidden="true">
          <img
            src="/terreno-esfuerzo.jpg"
            alt=""
            class="paraquien-photo"
          />
        </div>
      </div>
    </section>

    <!-- ===== FORMULARIO ===== -->
    <section class="formulario" id="formulario">
      <div class="container">
        <div class="form-wrapper">
          <div class="form-intro">
            <div class="section-label" style="color: #C8922A;">Acceso anticipado</div>
            <h2 class="section-title">QUIERO<br/>PROBAR EZTI.</h2>
            <p>
              Estamos en fase de validación. Si afrontas esfuerzos prolongados con regularidad y quieres ser de los primeros en probar EZTI, déjanos tus datos.
            </p>
            <ul class="form-perks">
              <li>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20"><path d="M4 10L8 14L16 6" stroke="#C8922A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Acceso prioritario al primer lote
              </li>
              <li>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20"><path d="M4 10L8 14L16 6" stroke="#C8922A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Muestra gratuita para testing real
              </li>
              <li>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20"><path d="M4 10L8 14L16 6" stroke="#C8922A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Tu feedback mejora el producto
              </li>
            </ul>
          </div>

          <div class="form-card">
            <p class="form-pretag">Testing real. Primer lote limitado.</p>
            <form id="contact-form" novalidate>
              <div class="form-group">
                <label for="nombre">Nombre</label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  placeholder="Tu nombre"
                  required
                  autocomplete="name"
                />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="tu@email.com"
                  required
                  autocomplete="email"
                />
              </div>
              <div class="form-group">
                <label for="deporte">Contexto de esfuerzo</label>
                <select id="deporte" name="deporte" required>
                  <option value="" disabled selected>¿Cuál es tu entorno?</option>
                  <option value="montana">Montaña y outdoor</option>
                  <option value="resistencia">Resistencia (ciclismo, triatlón, natación)</option>
                  <option value="running">Running (trail o asfalto)</option>
                  <option value="funcional">CrossFit, Hyrox o funcional</option>
                  <option value="combate">Deportes de combate</option>
                  <option value="trabajo">Trabajo físico exigente</option>
                  <option value="otro">Otro esfuerzo sostenido</option>
                </select>
              </div>
              <div class="form-group">
                <label for="mensaje">¿Por qué quieres probar EZTI? <span class="label-optional">(opcional)</span></label>
                <textarea
                  id="mensaje"
                  name="mensaje"
                  rows="3"
                  placeholder="Cuéntanos sobre tu entrenamiento o lo que buscas..."
                ></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-full" id="submit-btn">
                <span class="btn-text">Quiero probar EZTI</span>
                <span class="btn-loading" style="display:none">Enviando...</span>
              </button>
              <p class="form-privacy">
                Tus datos solo se usarán para contactarte sobre el proceso de testing de EZTI. Sin spam.
              </p>
            </form>

            <div class="form-success" id="form-success" style="display:none">
              <div class="success-icon" aria-hidden="true">
                <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg" width="60" height="60">
                  <circle cx="30" cy="30" r="28" stroke="#C8922A" stroke-width="2"/>
                  <path d="M18 30L26 38L42 22" stroke="#C8922A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>¡Apuntado!</h3>
              <p>Te avisaremos en cuanto tengamos unidades disponibles para testing. Energía real. Para seguir.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #080807;
    padding: 80px 0 60px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 110%, rgba(200, 146, 42, 0.06) 0%, transparent 55%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    max-width: 860px;
  }

  .honey-drip {
    width: 200px;
    max-width: 50vw;
    margin-bottom: 2rem;
    opacity: 0.95;
  }

  .hero-wordmark {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(5rem, 18vw, 13rem);
    color: #EDE7D8;
    letter-spacing: 0.06em;
    line-height: 0.9;
    margin-bottom: 1.5rem;
  }

  .hero-headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(1.1rem, 3.5vw, 1.85rem);
    color: #EDE7D8;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
  }

  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: rgba(237, 231, 216, 0.65);
    letter-spacing: 0.04em;
    margin: 0 0 2.75rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    animation: bounce 2.5s ease-in-out infinite;
    opacity: 0.5;
    transition: opacity 0.2s;
    display: flex;
  }

  .scroll-hint:hover { opacity: 1; }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0.85rem 2rem;
    border-radius: 2px;
    border: 2px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
    line-height: 1;
  }

  .btn-primary {
    background: #C8922A;
    color: #080807;
    border-color: #C8922A;
  }

  .btn-primary:hover {
    background: #EDE7D8;
    border-color: #EDE7D8;
    color: #080807;
  }

  .btn-outline {
    background: transparent;
    color: #EDE7D8;
    border-color: rgba(237, 231, 216, 0.3);
  }

  .btn-outline:hover {
    border-color: #EDE7D8;
    color: #EDE7D8;
  }

  .btn-full { width: 100%; }
  .btn:disabled { opacity: 0.6; cursor: not-allowed; }

  /* ===== MANIFIESTO ===== */
  .manifiesto {
    background: #EDE7D8;
    padding: 7rem 0;
  }

  .manifesto-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(8, 8, 7, 0.4);
    margin-bottom: 3rem;
  }

  .manifesto-body { max-width: 680px; }

  .manifesto-body p {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: #5C5748;
    line-height: 1.8;
    margin-bottom: 0.6rem;
  }

  .manifesto-ingredients {
    font-family: 'Barlow Condensed', sans-serif !important;
    font-weight: 900 !important;
    font-size: clamp(2.5rem, 6vw, 4.5rem) !important;
    color: #080807 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    margin: 1.75rem 0 !important;
    line-height: 1 !important;
  }

  .manifesto-close {
    margin-top: 1.75rem !important;
    color: #5C5748 !important;
    font-size: clamp(0.95rem, 2vw, 1.15rem) !important;
  }

  .manifesto-close strong {
    color: #080807;
    font-weight: 700;
  }

  /* ===== EDITORIAL STRIP ===== */
  .editorial-strip {
    position: relative;
    height: 72vh;
    min-height: 420px;
    overflow: hidden;
  }

  .editorial-photo-wrap {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .editorial-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .editorial-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 8, 7, 0.82) 0%,
      rgba(8, 8, 7, 0.35) 50%,
      rgba(8, 8, 7, 0.15) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 4rem;
  }

  .editorial-quote {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 4.2rem);
    color: #EDE7D8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.05;
    margin: 0;
    max-width: 820px;
  }

  .editorial-quote span {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: none;
    color: rgba(237, 231, 216, 0.55);
    margin-top: 1.25rem;
    line-height: 1.6;
  }

  /* ===== SECCIONES COMUNES ===== */
  .section-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #5C5748;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 5vw, 4rem);
    color: #EDE7D8;
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .section-intro {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: rgba(237, 231, 216, 0.6);
    max-width: 480px;
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  /* ===== PRODUCTO — split layout ===== */
  .producto {
    background: #080807;
  }

  .producto-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 75vh;
  }

  .producto-photo-panel {
    position: relative;
    overflow: hidden;
    min-height: 400px;
  }

  .producto-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .producto-features {
    padding: 5rem 4rem 5rem 4.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .product-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(92, 87, 72, 0.2);
  }

  .product-card {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 1rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(92, 87, 72, 0.12);
    align-items: start;
  }

  .product-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    color: rgba(92, 87, 72, 0.55);
    letter-spacing: 0.2em;
    padding-top: 0.25rem;
  }

  .product-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.3rem;
    color: #EDE7D8;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .product-card p {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: rgba(237, 231, 216, 0.45);
    line-height: 1.7;
    margin: 0;
  }

  /* ===== INGREDIENTES ===== */
  .ingredientes {
    background: #EDE7D8;
    padding: 7rem 0;
  }

  .ing-title { color: #080807 !important; }

  .ing-photo {
    margin: 2.5rem 0 4rem;
    height: 42vh;
    max-height: 460px;
    overflow: hidden;
    position: relative;
  }

  .ing-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }

  .ing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .ing-item { display: flex; flex-direction: column; }

  .ing-number {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    color: rgba(92, 87, 72, 0.6);
    letter-spacing: 0.2em;
    margin-bottom: 1.75rem;
    display: block;
    padding-bottom: 1rem;
