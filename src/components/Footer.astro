---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-wordmark">EZTI</span>
      <p class="footer-tagline">Miel, sal y limón para seguir.</p>
    </div>
    <div class="footer-links">
      <a href="#producto">El producto</a>
      <a href="#ingredientes">Ingredientes</a>
      <a href="#paraquien">Para quién</a>
      <a href="#formulario">Probar EZTI</a>
    </div>
    <p class="footer-legal">
      &copy; {year} EZTI. Hecho desde Euskadi.
    </p>
    <p class="footer-basque">
      Euskal Herrian sortua. Esfuerzoak merezi du.
    </p>
    <p class="footer-disclaimer">
      Las descripciones de este producto no constituyen declaraciones de propiedades saludables o de rendimiento en el sentido del Reglamento (CE) 1924/2006 ni del Reglamento (UE) 1169/2011. Ingredientes: miel, zumo de limón, sal de manantial. Fórmula sujeta a validación industrial y regulatoria. Producto alimentario envasado.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: #080807;
    border-top: 1px solid rgba(200, 146, 42, 0.2);
    padding: 4rem 0 3rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem 4rem;
    align-items: start;
  }

  .footer-brand {
    grid-column: 1 / -1;
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-wordmark {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 3rem;
    color: #EDE7D8;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #5C5748;
    margin: 0;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(237, 231, 216, 0.38);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: rgba(237, 231, 216, 0.75);
  }

  .footer-legal {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #5C5748;
    margin: 0;
    line-height: 1.6;
  }

  .footer-basque {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #5C5748;
    margin: 0.25rem 0 0;
    line-height: 1.6;
    opacity: 0.6;
  }

  .footer-disclaimer {
    grid-column: 1 / -1;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: rgba(92, 87, 72, 0.6);
    margin: 0;
    line-height: 1.7;
    border-top: 1px solid rgba(92, 87, 72, 0.15);
    padding-top: 1.5rem;
    margin-top: 1rem;
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1;
    }

    .footer-wordmark {
      font-size: 2.5rem;
    }
  }
</style>
