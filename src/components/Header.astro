---
---

<header class="site-header" id="site-header">
  <nav class="nav container">
    <a href="/" class="nav-logo" aria-label="EZTI — Inicio">
      <span class="wordmark">EZTI</span>
    </a>
    <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="nav-links">
      <li><a href="#producto">El producto</a></li>
      <li><a href="#ingredientes">Ingredientes</a></li>
      <li><a href="#paraquien">Para quién</a></li>
      <li><a href="#formulario" class="nav-cta">Probar EZTI</a></li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(8, 8, 7, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(200, 146, 42, 0.15);
    transition: background 0.3s ease;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .nav-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .wordmark {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.75rem;
    color: #EDE7D8;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-logo:hover .wordmark {
    color: #C8922A;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #EDE7D8;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #C8922A;
  }

  .nav-cta {
    background: #C8922A;
    color: #080807 !important;
    padding: 0.5rem 1.25rem;
    border-radius: 2px;
    font-weight: 600 !important;
    transition: background 0.2s !important;
  }

  .nav-cta:hover {
    background: #EDE7D8 !important;
    color: #080807 !important;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: #EDE7D8;
    transition: all 0.3s;
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: rgba(8, 8, 7, 0.97);
      flex-direction: column;
      padding: 1.5rem 1.25rem 2rem;
      gap: 1rem;
      border-bottom: 1px solid rgba(200, 146, 42, 0.2);
    }

    .nav-links.is-open {
      display: flex;
    }

    .nav-links a {
      font-size: 1rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid rgba(237, 231, 216, 0.08);
      width: 100%;
    }

    .nav-cta {
      text-align: center;
      border-bottom: none !important;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');

  toggle?.addEventListener('click', () => {
    const isOpen = links?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
      links?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
